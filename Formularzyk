<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <title>Formularz JS</title>
  <style>
    .error {
      border: 2px solid red;
    }
  </style>
</head>
<body>

<form id="myForm">
  <label>Wpisz tekst:</label>
  <input type="text" id="textInput">
  <span id="charCount">0 znaków</span>

  <br><br>

  <label>
    <input type="checkbox" id="myCheckbox">
    Zaznacz mnie
  </label>

  <br><br>

  <label>Hasło:</label>
  <input type="password" id="passwordInput">

  <br><br>

  <label>Wybierz kolor:</label>
  <select id="colorSelect">
    <option value="">-- wybierz --</option>
    <option value="red">Czerwony</option>
    <option value="green">Zielony</option>
    <option value="blue">Niebieski</option>
    <option value="yellow">Żółty</option>
  </select>

  <br><br>

  <button type="submit">Wyślij</button>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {

  const form = document.getElementById('myForm');
  const textInput = document.getElementById('textInput');
  const checkbox = document.getElementById('myCheckbox');
  const charCount = document.getElementById('charCount');
  const passwordInput = document.getElementById('passwordInput');
  const colorSelect = document.getElementById('colorSelect');

  form.addEventListener('submit', function(event) {
    event.preventDefault();
    console.log("Wartość pola tekstowego:", textInput.value);

    if (checkbox.checked) {
      console.log("Checkbox jest zaznaczony");
    } else {
      console.log("Checkbox NIE jest zaznaczony");
    }
  });

  textInput.addEventListener('input', function() {
    charCount.textContent = textInput.value.length + " znaków";
  });

  passwordInput.addEventListener('blur', function() {
    if (passwordInput.value.length < 8) {
      passwordInput.classList.add('error');
    } else {
      passwordInput.classList.remove('error');
    }
  });

  colorSelect.addEventListener('change', function() {
    document.body.style.backgroundColor = colorSelect.value;
  });

});
</script>

</body>
</html>
